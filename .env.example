# ProjetoX — Configuração de ambiente
# Crie um arquivo .env na raiz do projeto e copie estas variáveis

# === Obsidian Vault ===
# Caminho para o vault do Obsidian onde as notas serão salvas
# Default: C:\Users\<seu_user>\Documents\Obisidian\ProjetoX
OBSIDIAN_VAULT_PATH=C:\Users\v2admin\Documents\Obisidian\ProjetoX

# === OpenAI (Whisper + LLM opcional) ===
OPENAI_API_KEY=sk-sua-chave-aqui

# === Anthropic (LLM principal) ===
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# === Banco de Dados (quando Docker estiver ativo) ===
DATABASE_URL=postgresql+asyncpg://projetox:projetox@localhost:5432/projetox

# === Qdrant (busca semântica — quando Docker estiver ativo) ===
QDRANT_URL=http://localhost:6333
